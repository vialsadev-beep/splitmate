generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// AUTH / USERS
// ─────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  avatarUrl    String?
  passwordHash String?
  locale       String    @default("es")
  theme        String    @default("system")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  oauthAccounts    OAuthAccount[]
  groupMemberships GroupMember[]
  expensesPaid     Expense[]       @relation("ExpensePayer")
  splits           ExpenseSplit[]
  paymentsSent     Payment[]       @relation("PaymentSender")
  paymentsReceived Payment[]       @relation("PaymentReceiver")
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@map("users")
}

model OAuthAccount {
  id           String    @id @default(cuid())
  userId       String
  provider     String
  providerId   String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// GROUPS
// ─────────────────────────────────────────

model Group {
  id          String    @id @default(cuid())
  name        String
  description String?
  emoji       String?
  avatarUrl   String?
  currency    String    @default("EUR")
  inviteCode  String    @unique @default(cuid())
  debtLimit   Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members   GroupMember[]
  expenses  Expense[]
  payments  Payment[]
  categories Category[]
  budgets   Budget[]
  auditLogs AuditLog[]

  @@map("groups")
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

enum GroupRole {
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────

model Expense {
  id         String    @id @default(cuid())
  groupId    String
  payerId    String
  title      String
  amount     Decimal   @db.Decimal(12, 2)
  currency   String    @default("EUR")
  splitType  SplitType @default(EQUAL)
  categoryId String?
  notes      String?
  receiptUrl String?
  date       DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  group    Group          @relation(fields: [groupId], references: [id])
  payer    User           @relation("ExpensePayer", fields: [payerId], references: [id])
  splits   ExpenseSplit[]
  category Category?      @relation(fields: [categoryId], references: [id])

  @@index([groupId])
  @@index([payerId])
  @@map("expenses")
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
  SHARES
}

model ExpenseSplit {
  id        String   @id @default(cuid())
  expenseId String
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  isPaid    Boolean  @default(false)
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([userId])
  @@map("expense_splits")
}

// ─────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────

model Payment {
  id         String    @id @default(cuid())
  groupId    String
  senderId   String
  receiverId String
  amount     Decimal   @db.Decimal(12, 2)
  currency   String    @default("EUR")
  notes      String?
  date       DateTime  @default(now())
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  group    Group @relation(fields: [groupId], references: [id])
  sender   User  @relation("PaymentSender", fields: [senderId], references: [id])
  receiver User  @relation("PaymentReceiver", fields: [receiverId], references: [id])

  @@index([groupId])
  @@map("payments")
}

// ─────────────────────────────────────────
// CATEGORIES & BUDGETS
// ─────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  groupId   String?
  name      String
  emoji     String?
  color     String?
  createdAt DateTime @default(now())

  group    Group?    @relation(fields: [groupId], references: [id])
  expenses Expense[]
  budgets  Budget[]

  @@map("categories")
}

model Budget {
  id         String       @id @default(cuid())
  groupId    String
  categoryId String?
  name       String
  amount     Decimal      @db.Decimal(12, 2)
  period     BudgetPeriod @default(MONTHLY)
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime     @default(now())

  group    Group     @relation(fields: [groupId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  @@map("budgets")
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

enum NotificationType {
  EXPENSE_ADDED
  PAYMENT_RECEIVED
  DEBT_LIMIT
  GROUP_INVITE
  BUDGET_ALERT
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  groupId    String?
  entityType String
  entityId   String
  action     AuditAction
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user  User?  @relation(fields: [userId], references: [id])
  group Group? @relation(fields: [groupId], references: [id])

  @@index([entityType, entityId])
  @@index([groupId])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
}
