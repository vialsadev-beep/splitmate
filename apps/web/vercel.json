{
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter @splitmate/shared build && pnpm --filter @splitmate/web build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://splitmate-production-9842.up.railway.app/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://splitmate-production-9842.up.railway.app/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
